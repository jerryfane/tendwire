# Tendwire local defaults for source-mode Herdres integration.
# Copy values into your service manager or local env file; do not commit secrets.

# Herdr observation backend. Use socket for source-mode daily operation.
TENDWIRE_HERDR_BACKEND=socket

# Persistent local store for snapshots, command receipts, turns, attention, and
# connector outbox state.
TENDWIRE_DB_PATH=~/.local/share/tendwire/tendwire.db
# This path selects the main member of one private SQLite family. Tendwire
# validates the optional -wal, -shm, and -journal members as a unit. Ordinary
# diagnostics/status do not create or repair family members; startup/write
# preparation may create only a missing main file and only narrows permissions.

# Host-wide command idempotency is keyed by (host_id, request_id) after
# authoritative resolution to the canonical public worker identity. Mutating
# request IDs must match [A-Za-z0-9._-]{1,128} exactly and round-trip without
# trimming, normalization, or case-folding. Requests are schema 1; exact command
# envelopes are schema 2 by default, and their disposition—not status alone—is finality
# authority. backend_unavailable may be no_receipt (not terminal authority) or
# terminal_rejected (persisted pre-send terminal rejection). A different request
# ID remains a distinct send even when instruction text is identical.
TENDWIRE_COMMAND_RETRY_HORIZON_SECONDS=604800
TENDWIRE_COMMAND_RECEIPT_RETENTION_SECONDS=2592000
TENDWIRE_COMMAND_RECEIPT_RETENTION_COUNT=4096
# The retry horizon must be 1..604800 seconds. Receipt retention must be at
# least 691200 seconds and strictly greater than the retry horizon; its unchanged
# 2592000-second default also exceeds Herdres's maximum 604800-second connector
# retry horizon. The count must be positive. Cleanup keeps active reserved
# leases, converts only stale send_started rows to uncertain, and bounds expired
# reserved plus accepted/rejected/uncertain rows. A bounded row is deleted only
# when outside both the age and newest-count floors.

# Every instruction send is recorded in the submission ledger. Source-identity
# observations settle closed 1:1 link components after this symmetric window
# ends. The link does not affect turn identity, delivery, or ordering.
# The hard TTL expires an unlinked row after one day and must cover the window.
TENDWIRE_SUBMISSION_LINK_WINDOW_SECONDS=60
TENDWIRE_SUBMISSION_HARD_TTL_SECONDS=86400

# Authoritative complete finals enter the neutral outbox before Herdres is
# online. A routable root payload has schema_version 2 and the exact public
# opaque stable_key plus integer stable_key_version=1 captured from persisted
# turn metadata; final delivery never routes by worker fingerprint. A missing or
# malformed owner pair becomes a permanently nonretryable, nonpollable
# schema_version 1 final_migration_hold/dead_letter. An internal automation turn
# is also held and never routed, even if its public pair is valid. Queued,
# leased, deferred, retryable, awaiting-ACK, and dead-letter work is never
# removed by retention. Proven acknowledgments default to a 30-day / 4096-item
# per-host history window; unresolved overflow is aggregate storage pressure.
TENDWIRE_ACKNOWLEDGED_FINAL_RETENTION_DAYS=30
TENDWIRE_ACKNOWLEDGED_FINAL_RETENTION_COUNT=4096

# Connector transport retry and lease defaults. Exhausted eligible roots and
# failed plans stay inspectable until one exact opaque retry; missing-owner,
# malformed-owner, known-incomplete, and automation holds are inspection-only.
TENDWIRE_MAX_OUTBOX_ATTEMPTS=10
TENDWIRE_CONNECTOR_CLAIM_TTL_SECONDS=60
TENDWIRE_CONNECTOR_MAX_CLAIM_TTL_SECONDS=300
TENDWIRE_CONNECTOR_ACK_TTL_SECONDS=300

# Automatic snapshot cleanup defaults to 14 days and 4096 rows per host.
# Each host's latest row is always retained. At a 5-minute snapshot interval,
# 14 days × 288 snapshots/day ≈ 4032, leaving modest count-limit headroom.
TENDWIRE_SNAPSHOT_RETENTION_DAYS=14
TENDWIRE_SNAPSHOT_RETENTION_COUNT=4096

# Cleanup defaults to an hourly cadence and batches of 100 (maximum 1000), with
# a persisted least-recently-serviced host cursor. Retention days must be
# 1..365000, counts 1..9223372036854775807, batch size 1..1000, and cadence
# 1..31536000000 seconds. Automatic cleanup never runs VACUUM.
TENDWIRE_SNAPSHOT_MAINTENANCE_BATCH_SIZE=100
TENDWIRE_STORE_MAINTENANCE_CADENCE_SECONDS=3600

# Optional daemon socket sharing is disabled by default. If enabled, use a
# dedicated protected socket parent and a pre-existing trusted local group.
# TENDWIRE_SOCKET_PATH=/path/to/protected/tendwire.sock
# TENDWIRE_SOCKET_GROUP=tendwire-clients

# Optional stable host label for the local machine.
# TENDWIRE_HOST_ID=my-host

# Optional Herdr binary and timeout overrides. Turn-adapter reads use the same
# timeout.
# TENDWIRE_HERDR_BIN=herdr
TENDWIRE_HERDR_TIMEOUT_SECONDS=1.0

# Daemon-owned turn-ingestion cadence and dedicated worker pool. Defaults are
# 2.0 seconds and 4 workers; the worker count cannot exceed
# TENDWIRE_MAX_WORKERS. The internal refresh queue is fixed at 64.
TENDWIRE_TURN_REFRESH_INTERVAL_SECONDS=2.0
TENDWIRE_TURN_REFRESH_WORKERS=4
# Compatibility flag: legacy|dual|shadow|observed all use the observed model.
TENDWIRE_TURN_MODEL=observed

# Process-local bounded LRU for repeated public-text sanitization. Set to 0 to
# disable; values above 65536 are capped. The default covers typical retained
# turn and working-card reuse without sharing sanitized data between processes.
TENDWIRE_SANITIZE_CACHE_SIZE=2048

# Backend prompts remain visible as stale after a transient adapter failure for
# one fixed, non-sliding grace window. Repeated failures do not extend it.
TENDWIRE_PENDING_STALE_GRACE_SECONDS=30
